{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "inventario-ui": {
      "projectType": "library",
      "root": "projects/inventario-ui",
      "sourceRoot": "projects/inventario-ui/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/inventario-ui/ng-package.json",
            "tsConfig": "projects/inventario-ui/tsconfig.lib.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/inventario-ui/tsconfig.lib.prod.json"
            }
          }
        }
      }
    }
  }
}
